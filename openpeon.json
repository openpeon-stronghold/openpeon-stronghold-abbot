{
  "cesp_version": "1.0",
  "name": "stronghold-abbot",
  "display_name": "The Abbot (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/ab_add_player_01.wav", "label": "Praise be" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/ab_willattack_01.wav", "label": "Agreed" },
        { "file": "sounds/ab_siege_01.wav", "label": "Begin the siege" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/ab_vict_01.wav", "label": "Victory for me" },
        { "file": "sounds/ab_boast_01.wav", "label": "Watch and learn" },
        { "file": "sounds/ab_vict_04.wav", "label": "Going to rule this land" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/ab_anger_01.wav", "label": "My troops fail me" },
        { "file": "sounds/ab_anger_02.wav", "label": "You will pay for that" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/ab_help_01.wav", "label": "Send help" },
        { "file": "sounds/ab_req_01.wav", "label": "Short of materials" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/ab_notsent_01.wav", "label": "Not made of gold" },
        { "file": "sounds/ab_nohelp_01.wav", "label": "We will pray for you" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/ab_noattack_02.wav", "label": "Brothers are meditating" },
        { "file": "sounds/ab_kick_player_01.wav", "label": "No!" }
      ]
    }
  }
}
